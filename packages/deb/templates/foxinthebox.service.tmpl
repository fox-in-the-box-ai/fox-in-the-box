[Unit]
Description=Fox in the Box
Documentation=https://github.com/fox-in-the-box-ai/fox-in-the-box
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=/opt/foxinthebox

ExecStartPre=__APP_DIR__/scripts/preflight.sh
ExecStart=__APP_DIR__/venv/bin/supervisord -c /etc/foxinthebox/supervisord.conf

Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
