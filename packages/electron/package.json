{
  "name": "@fox-in-the-box/electron",
  "version": "0.1.0",
  "description": "Fox in the Box desktop app",
  "main": "src/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "jest --testPathPattern=tests/electron"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "electron-log": "^5.1.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "jest": {
    "rootDir": "../..",
    "testMatch": ["**/tests/electron/**/*.test.js"],
    "moduleDirectories": [
      "<rootDir>/packages/electron/node_modules",
      "node_modules"
    ]
  }
}
